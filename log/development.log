  [1m[36mArticle Create (4.8ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists say NAD+ could slow aging and fight Alzheimer’s and Parkinson’s', 'A global team of leading scientists is zeroing in on a tiny but powerful molecule that could reshape how we age. Known as NAD⁺, it plays a crucial role in keeping our cells energized, repairing DNA, and maintaining overall health—but its levels steadily decline over time, potentially fueling diseases like Alzheimer’s and Parkinson’s. Researchers are now exploring ways to boost NAD⁺ using compounds like NR and NMN, with early studies hinting at improvements in memory, metabolism, and physical function.', 'https://www.sciencedaily.com/releases/2026/03/260324024253.htm', 'ScienceDaily', '2026-03-24 10:39:06', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:30.172478', '2026-03-24 15:45:30.172478') RETURNING "id" /*application='GoodNews'*/[0m
