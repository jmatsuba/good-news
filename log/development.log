  [1m[36mTRANSACTION (2.3ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (5.0ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists thought ravens followed wolves. They were wrong', 'Ravens have long been thought to follow wolves to find food, but new research shows they’re far more strategic. By tracking both animals in Yellowstone, scientists discovered that ravens memorize areas where wolf kills are likely and fly directly to those spots—sometimes from great distances. Rather than trailing wolves, they rely on learned patterns in the landscape. It’s a clever system that highlights just how intelligent these birds really are.', 'https://www.sciencedaily.com/releases/2026/03/260319044643.htm', 'ScienceDaily', '2026-03-20 01:52:07', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:44.640221', '2026-03-24 15:45:44.640221') RETURNING "id" /*application='GoodNews'*/[0m
