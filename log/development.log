  [1m[36mArticle Create (4.3ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('New drug protects liver after intestinal surgery and boosts nutrient absorption', 'A risky but often lifesaving surgery that removes damaged parts of the small intestine can leave patients facing a new threat: serious liver damage with no available treatment. Now, scientists have developed a promising compound that works directly in the gut to shield the liver and improve how the body absorbs nutrients. In mouse studies, the drug boosted weight gain, reduced harmful liver scarring, and avoided side effects by staying confined to the intestines.', 'https://www.sciencedaily.com/releases/2026/03/260318033134.htm', 'ScienceDaily', '2026-03-18 07:31:34', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:46.387559', '2026-03-24 15:45:46.387559') RETURNING "id" /*application='GoodNews'*/[0m
