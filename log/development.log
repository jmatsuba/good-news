  [1m[36mArticle Create (4.8ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists recreated a dinosaur nest to solve a 70-million-year-old mystery', 'Scientists recreated a life-size oviraptor nest to understand how these dinosaurs hatched their eggs. Their experiments showed the parent likely couldn’t heat all the eggs directly, meaning sunlight played a key role. This uneven heating could cause eggs in the same nest to hatch at different times. The results suggest oviraptors used a hybrid incubation method unlike modern birds.', 'https://www.sciencedaily.com/releases/2026/03/260319005102.htm', 'ScienceDaily', '2026-03-19 04:58:27', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:45.481620', '2026-03-24 15:45:45.481620') RETURNING "id" /*application='GoodNews'*/[0m
