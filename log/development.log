  [1m[36mTRANSACTION (2.2ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (4.6ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists discover surprising brain trigger behind high blood pressure', 'Scientists have uncovered a surprising brain-based trigger for high blood pressure, tracing it to a small region in the brainstem that normally controls breathing. This area, which kicks in during forceful exhalations like coughing, laughing, or exercise, also appears to activate nerves that tighten blood vessels—raising blood pressure. When researchers switched off this region in experiments, blood pressure dropped back to normal, suggesting it plays a direct role in hypertension.', 'https://www.sciencedaily.com/releases/2026/03/260322020302.htm', 'ScienceDaily', '2026-03-23 03:30:22', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:34.327433', '2026-03-24 15:45:34.327433') RETURNING "id" /*application='GoodNews'*/[0m
