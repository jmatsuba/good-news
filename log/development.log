  [1m[36mTRANSACTION (1.2ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (2.8ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists turn CO2 into fuel using breakthrough single-atom catalyst', 'Researchers have created a cutting-edge catalyst that turns CO2 into methanol more efficiently than ever before. Instead of using clumps of metal atoms, they engineered a system where each single indium atom actively drives the reaction. This dramatically reduces energy needs while making the process easier to study and optimize. The result could accelerate the shift toward cleaner fuels and sustainable chemical production.', 'https://www.sciencedaily.com/releases/2026/03/260319044703.htm', 'ScienceDaily', '2026-03-20 08:31:08', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:43.194049', '2026-03-24 15:45:43.194049') RETURNING "id" /*application='GoodNews'*/[0m
