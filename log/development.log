  [1m[36mTRANSACTION (2.2ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (5.4ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Hidden antibiotics in river fish spark new food safety fears', 'Antibiotics are accumulating in a major Brazilian river, especially during the dry season when pollution becomes more concentrated. Scientists even detected a banned drug inside fish sold for food, raising concerns about human exposure. A common aquatic plant showed promise in removing these chemicals from water—but it also altered how fish absorb them, creating unexpected risks.', 'https://www.sciencedaily.com/releases/2026/03/260321012638.htm', 'ScienceDaily', '2026-03-22 00:48:07', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:39.540391', '2026-03-24 15:45:39.540391') RETURNING "id" /*application='GoodNews'*/[0m
