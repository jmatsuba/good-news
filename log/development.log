  [1m[36mArticle Create (3.9ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Insulin pills may soon replace daily injections', 'For over a century, scientists have chased the dream of insulin pills, but the digestive system kept destroying the drug before it could work—forcing millions of patients to rely on daily injections. Now, researchers at Kumamoto University have developed a clever workaround using a tiny peptide that helps insulin slip through the intestinal wall.', 'https://www.sciencedaily.com/releases/2026/03/260324024302.htm', 'ScienceDaily', '2026-03-24 08:08:11', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:29.007150', '2026-03-24 15:45:29.007150') RETURNING "id" /*application='GoodNews'*/[0m
