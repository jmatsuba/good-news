  [1m[36mTRANSACTION (1.3ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (3.3ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('New light trap design supercharges atom-thin semiconductors', 'Scientists have found a clever way to supercharge ultra-thin semiconductors by reshaping the space beneath them rather than altering the material itself. By placing a single-atom-thick layer of tungsten disulfide over tiny air cavities carved into a crystal, they created miniature “light traps” that dramatically boost brightness and optical effects—up to 20 times stronger emission and 25 times stronger nonlinear signals. These hollow structures, called Mie voids, concentrate light exactly where the material sits, overcoming a major limitation of atomically thin devices.', 'https://www.sciencedaily.com/releases/2026/03/260324024257.htm', 'ScienceDaily', '2026-03-24 07:25:15', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:29.578417', '2026-03-24 15:45:29.578417') RETURNING "id" /*application='GoodNews'*/[0m
