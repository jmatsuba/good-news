  [1m[36mArticle Create (4.1ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('A promising fatty liver treatment may raise cancer risk', 'A surprising new study reveals that blocking a supposedly protective enzyme, Caspase-2, could actually backfire—raising the risk of chronic liver damage and cancer over time. Researchers found that without this enzyme, liver cells grow abnormally large and accumulate genetic damage, leading to inflammation, scarring, and eventually tumors, especially with age. While inhibiting Caspase-2 may offer short-term benefits, such as reducing fatty liver disease, the long-term consequences appear dangerous.', 'https://www.sciencedaily.com/releases/2026/03/260323005545.htm', 'ScienceDaily', '2026-03-23 07:13:52', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:31.397588', '2026-03-24 15:45:31.397588') RETURNING "id" /*application='GoodNews'*/[0m
