  [1m[36mTRANSACTION (2.2ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (5.2ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Friction without contact discovered as magnetic forces break a 300-year-old law', 'Researchers have uncovered friction without contact—driven entirely by magnetic interactions. As two magnetic layers slide, their internal forces compete, causing constant rearrangements that dramatically increase resistance at certain distances. This creates a surprising peak in friction instead of a steady rise, breaking a long-standing physics law.', 'https://www.sciencedaily.com/releases/2026/03/260322020243.htm', 'ScienceDaily', '2026-03-22 09:17:40', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:36.797730', '2026-03-24 15:45:36.797730') RETURNING "id" /*application='GoodNews'*/[0m
