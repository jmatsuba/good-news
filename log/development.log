  [1m[36mTRANSACTION (1.7ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (3.7ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists solve 12,800-year-old climate mystery hidden in Greenland ice', 'A mysterious spike of platinum buried deep in Greenland’s ice has long fueled theories of a catastrophic comet or asteroid strike 12,800 years ago—possibly triggering a sudden return to icy conditions known as the Younger Dryas. But new research points to a far less dramatic, yet still powerful culprit: volcanic eruptions. Scientists found the platinum signal doesn’t match space debris and actually appeared decades after the cooling began, ruling out an impact as the trigger.', 'https://www.sciencedaily.com/releases/2026/03/260319044714.htm', 'ScienceDaily', '2026-03-20 10:01:12', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:42.329257', '2026-03-24 15:45:42.329257') RETURNING "id" /*application='GoodNews'*/[0m
