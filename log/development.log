  [1m[36mTRANSACTION (1.9ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (4.1ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists discover Alzheimer’s hidden “death switch” in the brain', 'Scientists have uncovered a hidden “death switch” in the brain that may be driving Alzheimer’s disease—and even found a way to turn it off in mice. The culprit is a toxic pairing of two proteins that, when combined, triggers the destruction of brain cells and fuels memory loss. By using a new compound to break apart this deadly duo, researchers were able to slow disease progression, protect brain cells, and even reduce hallmark amyloid buildup.', 'https://www.sciencedaily.com/releases/2026/03/260323005526.htm', 'ScienceDaily', '2026-03-23 09:34:10', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:33.990086', '2026-03-24 15:45:33.990086') RETURNING "id" /*application='GoodNews'*/[0m
