  [1m[36mArticle Create (3.8ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('This common vaccine cuts heart risk nearly in half in new study', 'A shingles vaccine might double as a powerful heart protector. In people already at high risk, it cut major cardiac events by 46% and deaths by an impressive 66% within a year. Scientists think preventing shingles may also stop clot-related complications that can lead to heart attacks and strokes. The effect is so strong, it rivals the benefits of quitting smoking.', 'https://www.sciencedaily.com/releases/2026/03/260319044659.htm', 'ScienceDaily', '2026-03-20 12:10:25', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:43.475411', '2026-03-24 15:45:43.475411') RETURNING "id" /*application='GoodNews'*/[0m
