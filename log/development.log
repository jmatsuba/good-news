  [1m[36mTRANSACTION (2.3ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (5.1ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Beavers are turning rivers into powerful carbon sinks', 'Beavers may be unlikely climate heroes, but new research suggests they could play a powerful role in fighting climate change. By building dams and transforming streams into wetlands, these industrious animals dramatically reshape how carbon moves and is stored in landscapes. Over just 13 years, a beaver-engineered wetland in Switzerland stored over a thousand tonnes of carbon—up to ten times more than similar areas without beavers.', 'https://www.sciencedaily.com/releases/2026/03/260322020245.htm', 'ScienceDaily', '2026-03-22 11:21:20', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:36.500749', '2026-03-24 15:45:36.500749') RETURNING "id" /*application='GoodNews'*/[0m
