  [1m[36mTRANSACTION (1.4ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (3.6ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Women over 50 lost 35% more weight with this surprising combo', 'Postmenopausal women may have a powerful new edge in the battle against weight gain. A Mayo Clinic study found that those using menopausal hormone therapy while taking the obesity drug tirzepatide lost about 35% more weight than those on the drug alone. The findings hint at a surprising synergy between hormones and cutting-edge weight-loss medications, potentially opening the door to more effective, personalized treatments for millions of women facing increased cardiometabolic risks after menopause.', 'https://www.sciencedaily.com/releases/2026/03/260323005543.htm', 'ScienceDaily', '2026-03-24 01:06:37', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:31.669299', '2026-03-24 15:45:31.669299') RETURNING "id" /*application='GoodNews'*/[0m
