  [1m[36mArticle Create (4.5ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('This floating time crystal breaks Newton’s third law of motion', 'Scientists have created a new kind of time crystal using sound waves to levitate tiny beads in mid-air. These particles interact in a one-sided, unbalanced way, breaking the usual rules of motion and creating a steady, repeating rhythm. The system is surprisingly simple yet reveals complex physics with big implications. It could help advance quantum computing and deepen our understanding of biological timing systems.', 'https://www.sciencedaily.com/releases/2026/03/260322020258.htm', 'ScienceDaily', '2026-03-23 01:54:16', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:34.941301', '2026-03-24 15:45:34.941301') RETURNING "id" /*application='GoodNews'*/[0m
