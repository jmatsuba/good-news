  [1m[36mTRANSACTION (2.2ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (4.7ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('A massive freshwater reservoir is hiding under the Great Salt Lake', 'A hidden freshwater system deep beneath the Great Salt Lake has been revealed using airborne electromagnetic surveys. Scientists found that freshwater extends much farther under the lake than expected, reaching depths of up to 4 kilometers. The discovery began with mysterious reed-covered mounds formed by pressurized groundwater pushing upward. Researchers are now investigating whether this underground water could help control hazardous dust from the drying lakebed.', 'https://www.sciencedaily.com/releases/2026/03/260321012640.htm', 'ScienceDaily', '2026-03-22 01:20:18', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:39.245266', '2026-03-24 15:45:39.245266') RETURNING "id" /*application='GoodNews'*/[0m
