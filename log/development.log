  [1m[36mTRANSACTION (1.6ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (3.9ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('The best strength training plan might be simpler than you think', 'New strength training guidelines emphasize that doing any resistance training is what truly matters. Based on decades of research, experts say even simple routines can increase muscle, strength, and physical function. The key is not perfection but consistency. In fact, the best workout plan is the one you can maintain long term.', 'https://www.sciencedaily.com/releases/2026/03/260319074552.htm', 'ScienceDaily', '2026-03-19 12:09:07', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:41.633621', '2026-03-24 15:45:41.633621') RETURNING "id" /*application='GoodNews'*/[0m
