  [1m[36mArticle Create (4.7ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Scientists turn probiotic bacteria into tumor-hunting cancer killers', 'Scientists have engineered probiotic bacteria to act as tumor-seeking drug factories. In mice, these bacteria infiltrated tumors and produced a cancer-fighting drug right where it was needed. This targeted approach could make treatments more effective and reduce side effects. More research is needed before it can be tested in people.', 'https://www.sciencedaily.com/releases/2026/03/260321004445.htm', 'ScienceDaily', '2026-03-21 05:26:09', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:40.153298', '2026-03-24 15:45:40.153298') RETURNING "id" /*application='GoodNews'*/[0m
