  [1m[36mTRANSACTION (1.9ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (3.9ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Supercomputers just solved a 50-year-old mystery about giant stars', 'Astronomers have finally cracked a decades-old mystery about red giant stars—how material from their deep interiors makes its way to the surface. Using cutting-edge supercomputer simulations, researchers discovered that stellar rotation plays a powerful role in mixing elements across a previously unexplained barrier inside the star.', 'https://www.sciencedaily.com/releases/2026/03/260324024300.htm', 'ScienceDaily', '2026-03-24 11:52:48', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:29.303725', '2026-03-24 15:45:29.303725') RETURNING "id" /*application='GoodNews'*/[0m
