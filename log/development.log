  [1m[36mTRANSACTION (1.7ms)[0m  [1m[35mBEGIN /*application='GoodNews'*/[0m
  [1m[36mArticle Create (4.0ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('The surprising cancer link between cats and humans', 'Scientists have mapped the genetics of cancer in cats for the first time at scale, uncovering major overlaps with human cancers. Key mutations—like those linked to breast cancer—appear in both species, and some human cancer drugs may also work in cats. Because pets share our environments, these similarities could reveal shared causes of cancer. The research could lead to new treatments that benefit both animals and humans.', 'https://www.sciencedaily.com/releases/2026/03/260318033143.htm', 'ScienceDaily', '2026-03-18 23:12:17', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:45.780449', '2026-03-24 15:45:45.780449') RETURNING "id" /*application='GoodNews'*/[0m
