  [1m[36mArticle Create (7.6ms)[0m  [1m[32mINSERT INTO "articles" ("title", "summary", "url", "source_name", "published_at", "image_url", "positivity", "sensationalism", "political_controversy", "fit_score", "status", "highlighted", "classification_json", "created_at", "updated_at") VALUES ('Harvard engineers build chip that can twist and control light in real time', 'Scientists at Harvard have built a miniature device that can twist and tune light in real time. By rotating two stacked photonic crystals and adjusting their spacing with a tiny mechanical system, they can control how light’s “handedness” behaves. This allows the chip to distinguish between left- and right-circular polarized light with remarkable precision. The advance could lead to smarter sensors, faster communications, and new quantum technologies.', 'https://www.sciencedaily.com/releases/2026/03/260321012702.htm', 'ScienceDaily', '2026-03-21 11:34:39', NULL, NULL, NULL, NULL, NULL, 'REJECTED', FALSE, '{"error":"classification_failed"}', '2026-03-24 15:45:38.027256', '2026-03-24 15:45:38.027256') RETURNING "id" /*application='GoodNews'*/[0m
