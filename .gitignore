# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ------------------------------------------------------------------------------
# Rails (logs, tmp, local uploads — matches github/gitignore Rails.gitignore)
# ------------------------------------------------------------------------------
/log/*
!/log/.keep

/tmp/*
!/tmp/.keep

/tmp/pids/*
!/tmp/pids/.keep

/tmp/sockets/*
!/tmp/sockets/.keep

/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Bootsnap lives under tmp/cache; covered by /tmp/*, listed explicitly for clarity
/tmp/cache/bootsnap/

# Local TLS / dev certs sometimes dropped in project root
*.crt

# Ruby / tooling caches
/.rubocop_cache/
/.yardoc/
/.byebug_history

# Optional local gem vendoring
/vendor/bundle

# ------------------------------------------------------------------------------
# dependencies
# ------------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/public/assets

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Ignore key files for decrypting credentials and more.
/config/*.key


/app/assets/builds/*
!/app/assets/builds/.keep
