<div class="min-h-screen bg-[#faf8f5] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-amber-100/40 via-transparent to-transparent">
  <header class="border-b border-stone-200/60 bg-white/40 backdrop-blur-md">
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-10 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-3">
        <p class="text-xs font-medium uppercase tracking-[0.35em] text-amber-800/80">Curated calm</p>
        <h1 class="font-serif text-4xl tracking-tight text-stone-900 sm:text-5xl">Good News</h1>
        <p class="max-w-xl text-sm leading-relaxed text-stone-600">
          Uplifting stories from trusted feeds—filtered for positivity, lower sensationalism, and a steadier tone.
        </p>
      </div>
      <%= render "feed_toolbar", q: @q, tag: @tag, sort: @sort %>
      <%= render "category_chips", tags: @tag_items, active_slug: @tag, preserve_q: @q, preserve_sort: (@sort != "newest" ? @sort : nil) %>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <% if @show_spotlight %>
      <section class="mb-12" aria-labelledby="spotlight-heading">
        <h2 id="spotlight-heading" class="mb-6 font-serif text-2xl text-stone-900">Spotlight</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <% @hero.first(1).each do |a| %>
            <div class="md:col-span-2 lg:col-span-3">
              <%= render "article_card", article: a, variant: :hero %>
            </div>
          <% end %>
          <% @hero.drop(1).each do |a| %>
            <%= render "article_card", article: a, variant: :grid %>
          <% end %>
        </div>
      </section>
    <% end %>

    <section aria-labelledby="feed-heading">
      <div class="mb-6">
        <h2 id="feed-heading" class="font-serif text-2xl text-stone-900">
          <%= @q.present? ? "Search results" : "Latest" %>
        </h2>
        <% if @q.present? %>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-stone-600">
            Matching <span class="font-medium text-stone-800">“<%= @q %>”</span>
            <% if @tag.present? %>
              in <span class="font-medium text-stone-800"><%= @active_tag_label || @tag %></span>
            <% end %>.
          </p>
        <% else %>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-stone-600">
            <% if @tag.present? %>
              Stories tagged <span class="font-medium text-stone-800"><%= @active_tag_label || @tag %></span>—newest first.
              Choose <span class="font-medium text-stone-800">All</span> above to see every topic again.
            <% else %>
              Newest good-news picks from every category and source—browse in full below. Use the tags
              at the top when you want to focus on something like Tech, Health, or Science.
            <% end %>
          </p>
        <% end %>
      </div>

      <% if @articles.empty? %>
        <p class="rounded-2xl border border-dashed border-stone-300/80 bg-white/50 px-6 py-12 text-center text-sm text-stone-600">
          No stories match yet. Try another search or category.
        </p>
      <% else %>
        <ul class="flex flex-col gap-3 sm:gap-3.5">
          <% @articles.each do |a| %>
            <li><%= render "article_card", article: a, variant: :compact %></li>
          <% end %>
        </ul>
      <% end %>

      <% if @has_more %>
        <div class="mt-10 flex justify-center">
          <%= link_to "Load more", root_path(@next_params),
              class: "rounded-full border border-stone-300 bg-white px-6 py-2.5 text-sm font-medium text-stone-800 shadow-sm transition hover:border-amber-300 hover:bg-amber-50/60" %>
        </div>
      <% end %>
    </section>
  </main>

  <footer class="border-t border-stone-200/60 py-8 text-center text-xs text-stone-500">
    Links open original publishers. Summaries are excerpts for discovery.
  </footer>
</div>
