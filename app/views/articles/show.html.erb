<% content_for :title, @page_title %>
<% content_for :head do %>
  <meta name="description" content="<%= @page_description %>">
<% end %>

<article class="group mx-auto min-h-screen max-w-3xl bg-[#faf8f5] px-4 py-12 sm:px-6">
  <%= link_to "← Back", root_path, class: "mb-8 inline-flex text-sm font-medium text-amber-900/80 underline-offset-4 hover:underline" %>

  <div class="mb-6 flex flex-wrap gap-2">
    <% @article.tags.each do |t| %>
      <span class="rounded-full bg-stone-200/80 px-3 py-1 text-xs font-medium uppercase tracking-wider text-stone-700"><%= t.label %></span>
    <% end %>
  </div>

  <h1 class="font-serif text-3xl leading-tight tracking-tight text-stone-900 sm:text-4xl"><%= @article.title %></h1>
  <p class="mt-3 text-sm text-stone-500">
    <%= @article.source_name %> ·
    <time datetime="<%= @article.published_at.iso8601 %>"><%= format_relative_time(@article.published_at) %></time>
  </p>

  <% if @article.image_url.present? %>
    <%= image_tag @article.image_url, alt: "", class: "mt-8 w-full rounded-2xl object-cover shadow-sm grayscale transition duration-500 ease-out group-hover:grayscale-0" %>
  <% end %>

  <p class="mt-8 text-lg leading-relaxed text-stone-700"><%= @article.summary %></p>

  <%= link_to "Read full article", @article.url, target: "_blank", rel: "noopener noreferrer",
      class: "mt-10 inline-flex rounded-full bg-stone-900 px-6 py-3 text-sm font-medium text-amber-50 transition hover:bg-stone-800" %>
</article>
