<div class="mx-auto max-w-4xl px-4 py-10">
  <h1 class="font-serif text-2xl text-stone-900">Rejected (last 50)</h1>
  <p class="mt-2 text-sm text-stone-600">For debugging classification thresholds.</p>
  <ul class="mt-8 space-y-6">
    <% @articles.each do |a| %>
      <li class="rounded-xl border border-stone-200 bg-white p-4 text-sm">
        <p class="font-medium text-stone-900"><%= a.title %></p>
        <p class="mt-1 text-xs text-stone-500"><%= a.url %></p>
        <pre class="mt-2 max-h-40 overflow-auto rounded bg-stone-50 p-2 text-xs text-stone-700"><%= JSON.pretty_generate(a.classification_json || {}) %></pre>
      </li>
    <% end %>
  </ul>
</div>
