# Local Postgres (see docker-compose.yml — port 5433 on host)
DATABASE_URL="postgresql://goodnews:goodnews@127.0.0.1:5433/goodnews"

# Google Gemini — required for automated classification during ingest (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional model id (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Secret for /ingest (manual triggers). Use a long random string in production.
# - Header: Authorization: Bearer <INGEST_SECRET>
# - Bookmark: https://YOUR_DOMAIN/ingest?secret=INGEST_SECRET&ui=1
# Cron / recurring jobs: set CRON_SECRET and configure your scheduler to send Bearer CRON_SECRET if you trigger HTTP instead of Solid Queue.
INGEST_SECRET=dev-secret-change-me
CRON_SECRET=

# Classification thresholds (0–10)
MIN_POSITIVITY=6
MAX_SENSATIONALISM=5
MAX_POLITICAL_CONTROVERSY=6
MIN_FIT_SCORE=6

# Comma-separated extra RSS URLs (optional; defaults are in config/feeds.json)
# RSS_FEED_URLS=

# Fetch og:image when RSS has no image (slower)
# ENRICH_OG_IMAGES=true

# Optional: canonical site URL for future meta tags
# SITE_URL=https://good-news.example.com
