# Local Postgres (see docker-compose.yml — port 5433 on host)
DATABASE_URL="postgresql://goodnews:goodnews@localhost:5433/goodnews"

# OpenAI — required for automated classification during ingest
OPENAI_API_KEY=

# Secret for /api/ingest (manual triggers). Use a long random string in production.
# - Header: Authorization: Bearer <INGEST_SECRET>
# - Private URL (bookmark in browser): https://YOUR_DOMAIN/api/ingest?secret=INGEST_SECRET&ui=1
#   (&ui=1 returns a simple HTML result page; omit for JSON). Query secrets can appear in server logs—prefer Bearer when scripting.
# Vercel Cron: Authorization: Bearer <CRON_SECRET>
INGEST_SECRET=dev-secret-change-me
CRON_SECRET=

# Classification thresholds (0–10 scales except positivity 0–10)
MIN_POSITIVITY=6
MAX_SENSATIONALISM=5
MAX_POLITICAL_CONTROVERSY=6
MIN_FIT_SCORE=6

# Comma-separated RSS feed URLs (optional override; defaults in src/config/feeds.json)
# RSS_FEED_URLS=

# Optional: canonical site URL for Open Graph (e.g. https://good-news.example.com)
# NEXT_PUBLIC_SITE_URL=

# Optional: OpenAI model override (default gpt-4o-mini)
# OPENAI_MODEL=

# During API ingest, fetch each article page for og:image when RSS has no image (slower, more HTTP)
# ENRICH_OG_IMAGES=true
