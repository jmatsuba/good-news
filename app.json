{
  "healthchecks": {
    "web": [
      {
        "type": "startup",
        "name": "rails-up",
        "description": "Rails built-in health endpoint",
        "path": "/up",
        "port": 80,
        "attempts": 5,
        "timeout": 5,
        "wait": 5,
        "initialDelay": 5
      }
    ]
  }
}
